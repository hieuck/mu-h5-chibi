{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["jest"],
    "paths": {
      "@game/*": ["./game/*"]
    }
  },
  "include": ["game/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
